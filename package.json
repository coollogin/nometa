{
  "name": "nometa",
  "version": "1.0.4",
  "description": "Очистка метаданных из офисных документов",
  "main": "main/main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dev": "electron . --env development --no-sandbox",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.nometa.app",
    "productName": "NoMeta",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "services/**/*",
      "utils/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NoMeta"
    },
    "portable": {
      "artifactName": "NoMeta-${version}-portable.exe"
    }
  },
  "engines": {
    "node": "18.17.1"
  },
  "devDependencies": {
    "@electron/remote": "^2.1.3",
    "electron": "22.3.27",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "archiver": "^8.0.0",
    "iconv-lite": "^0.6.3",
    "odf-kit": "^0.13.5",
    "pdf-lib": "^1.17.1",
    "simple-odf": "^3.0.3",
    "unzipper": "^0.12.3",
    "yazl": "^3.3.1",
    "zip-a-folder": "^6.1.1"
  }
}